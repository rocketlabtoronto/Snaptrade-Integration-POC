# SnapTrade API Credentials
# Copy this file to .env and update with your actual credentials

# Backward-compatible default credentials (used if explicit environment credentials are missing)
SNAPTRADE_CLIENT_ID=your-default-client-id-here
SNAPTRADE_CONSUMER_KEY=your-default-consumer-key-here

# Production SnapTrade credentials
SNAPTRADE_PRODUCTION_CLIENT_ID=your-production-client-id-here
SNAPTRADE_PRODUCTION_CONSUMER_KEY=your-production-consumer-key-here

# Development SnapTrade credentials
SNAPTRADE_DEVELOPMENT_CLIENT_ID=
SNAPTRADE_DEVELOPMENT_CONSUMER_KEY=

# Default SnapTrade environment for startup and initial UI load
SNAPTRADE_ENV=production

# Supabase persistence for Production
SUPABASE_PRODUCTION_URL=
SUPABASE_PRODUCTION_SERVICE_ROLE_KEY=
SUPABASE_PRODUCTION_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase persistence for Development
SUPABASE_DEVELOPMENT_URL=
SUPABASE_DEVELOPMENT_SERVICE_ROLE_KEY=
SUPABASE_DEVELOPMENT_ANON_KEY=

# Optional frontend-style aliases currently used for Development fallback
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Backend Server Configuration
BACKEND_PORT=3005
